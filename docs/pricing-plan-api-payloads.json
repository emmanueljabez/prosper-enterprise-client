  "item": [
    {
      "name": "Pricing Products",
      "item": [
        {
          "name": "List Public Pricing Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pricing/products?audience=MENTEE",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pricing",
                "products"
              ],
              "query": [
                {
                  "key": "audience",
                  "value": "MENTEE"
                }
              ]
            },
            "description": "Returns visible active session-commerce pricing products for the pricing page."
          },
          "response": []
        },
        {
          "name": "List Public Pricing Products Alias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/public/session-commerce/products?audience=MENTEE",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "public",
                "session-commerce",
                "products"
              ],
              "query": [
                {
                  "key": "audience",
                  "value": "MENTEE"
                }
              ]
            },
            "description": "Alias for public pricing products."
          },
          "response": []
        },
        {
          "name": "Admin List Pricing Products",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/pricing/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "pricing",
                "products"
              ]
            },
            "description": "Admin-only list of all pricing products, including inactive/hidden products."
          },
          "response": []
        },
        {
          "name": "Admin Update Pricing Product",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"5-Session Pack\",\n  \"subtitle\": \"Consistent growth path\",\n  \"currency\": \"KES\",\n  \"priceAmount\": 17500,\n  \"creditQuantity\": 5,\n  \"sessionDurationMinutes\": 45,\n  \"trialWindowDays\": null,\n  \"slotHoldMinutes\": 15,\n  \"displayOrder\": 4,\n  \"badgeLabel\": \"ACCOUNTABILITY\",\n  \"badgeTone\": \"success\",\n  \"savingsLabel\": \"SAVE KES 2,500\",\n  \"featureItems\": [\n    \"Monthly career audits\",\n    \"Long-term goal setting\",\n    \"Priority scheduling\"\n  ],\n  \"noRefundPolicyVersion\": \"NO_REFUND_V1\",\n  \"active\": true,\n  \"visible\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/pricing/products/{{productIdOrSku}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "pricing",
                "products",
                "{{productIdOrSku}}"
              ]
            },
            "description": "Admin-only pricing product update. productIdOrSku can be a UUID or SKU. All body fields are optional."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Single Session Checkout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mentorId\": \"{{mentorId}}\",\n  \"menteeId\": \"{{menteeId}}\",\n  \"skillId\": \"{{skillId}}\",\n  \"scheduledStart\": \"2026-06-25T09:00:00+03:00\",\n  \"meetingPlatform\": \"GOOGLE_MEET\",\n  \"menteeMessage\": \"I want help clarifying my career roadmap.\",\n  \"questionnaireResponses\": {\n    \"primaryGoal\": \"Clarify my leadership roadmap\",\n    \"alreadyTried\": \"Completed one internal course\",\n    \"successLooksLike\": \"A clear 30-day action plan\",\n    \"contextLinks\": \"https://example.com/context\"\n  },\n  \"noRefundAccepted\": true,\n  \"redirectSuccessUrl\": \"https://enterprise.prospermentor.com/app/sessions\",\n  \"redirectCancelUrl\": \"https://enterprise.prospermentor.com/pricing\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkouts/session",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkouts",
                "session"
              ]
            },
            "description": "Creates a self-pay single-session checkout invoice. noRefundAccepted must be true."
          },
          "response": []
        },
        {
          "name": "Bundle Checkout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{menteeId}}\",\n  \"productSku\": \"BUNDLE_MID\",\n  \"redirectSuccessUrl\": \"https://enterprise.prospermentor.com/app/sessions\",\n  \"redirectCancelUrl\": \"https://enterprise.prospermentor.com/pricing\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkouts/bundle",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkouts",
                "bundle"
              ]
            },
            "description": "Creates a checkout invoice for a session bundle. Valid bundle SKUs: BUNDLE_SHORT, BUNDLE_MID, BUNDLE_LONG."
          },
          "response": []
        },
        {
          "name": "Credit-Funded Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mentorId\": \"{{mentorId}}\",\n  \"menteeId\": \"{{menteeId}}\",\n  \"skillId\": \"{{skillId}}\",\n  \"scheduledStart\": \"2026-06-25T09:00:00+03:00\",\n  \"meetingPlatform\": \"GOOGLE_MEET\",\n  \"menteeMessage\": \"I want help preparing for a role transition.\",\n  \"questionnaireResponses\": {\n    \"primaryGoal\": \"Prepare for role transition\",\n    \"alreadyTried\": \"Updated my CV\",\n    \"successLooksLike\": \"Clear interview strategy\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/credit-bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "credit-bookings"
              ]
            },
            "description": "Books a session using existing personal/bundle credits."
          },
          "response": []
        },
        {
          "name": "Funding Options",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/funding-options?menteeId={{menteeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "funding-options"
              ],
              "query": [
                {
                  "key": "menteeId",
                  "value": "{{menteeId}}"
                }
              ]
            },
            "description": "Returns employer allocation, bundle credit, and self-pay options for a mentee."
          },
          "response": []
        }
      ]
    },
    {
